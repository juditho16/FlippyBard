{
  "expo": {
    "name": "Flippy Bard",
    "slug": "flappy-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "assets/splash.png",
