        "backgroundColor": "#70c5ce"
      },
      "package": "com.flippybard.game",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6907d530-0bfe-4b85-b380-7b4488620d3a"
      }
    }
  }
